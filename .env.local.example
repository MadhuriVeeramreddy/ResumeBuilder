# ── Provider selection ──────────────────────────────────────────────
# "google"     → Google AI Studio (has a free tier; uses GOOGLE_API_KEY)
# "openrouter" → OpenRouter (uses OPENROUTER_API_KEY)
LLM_PROVIDER=google

# ── Google AI Studio (LLM_PROVIDER=google) ──────────────────────────
# Get a key at https://aistudio.google.com → "Get API key"
GOOGLE_API_KEY=your-google-ai-studio-key
# Google models use the OpenAI-compatible endpoint; no "google/" prefix.
RESUME_MODEL=gemini-2.5-flash
RESUME_FALLBACKS=gemini-2.5-flash-lite

# ── OpenRouter (LLM_PROVIDER=openrouter) ────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Example OpenRouter models (uncomment + set RESUME_MODEL/RESUME_FALLBACKS):
# RESUME_MODEL=google/gemini-2.5-flash
# RESUME_FALLBACKS=openai/gpt-4.1-mini,google/gemini-2.5-flash-lite,openai/gpt-oss-20b:free

# ── Pipeline tuning ─────────────────────────────────────────────────
GEN_MAX_ATTEMPTS=3
GEN_CONCURRENCY=2
